\c genuai_db
CREATE TABLE users (  id SERIAL PRIMARY KEY,  name VARCHAR(255) NOT NULL,  email VARCHAR(255) UNIQUE NOT NULL,  password_hash VARCHAR(255) NOT NULL,  role VARCHAR(50) DEFAULT 'candidate',  created_at TIMESTAMP DEFAULT NOW());CREATE TABLE jobs (  id SERIAL PRIMARY KEY,  company_id INTEGER REFERENCES users(id),  title VARCHAR(255) NOT NULL,  description TEXT,  skills_required TEXT,  location VARCHAR(255),  salary_min INTEGER,  salary_max INTEGER,  posted_at TIMESTAMP DEFAULT NOW());CREATE TABLE assessments (  id SERIAL PRIMARY KEY,  user_id INTEGER REFERENCES users(id),  job_id INTEGER REFERENCES jobs(id),  resume_text TEXT,  resume_url VARCHAR(500),  skills TEXT,  ats_score INTEGER DEFAULT 0,  resume_score INTEGER DEFAULT 0,  interview_score INTEGER DEFAULT 0,  test_score INTEGER DEFAULT 0,  consistency_score INTEGER DEFAULT 0,  overall_score INTEGER DEFAULT 0,  authenticity_score INTEGER DEFAULT 0,  verdict VARCHAR(50),  triangle_status VARCHAR(50),  salary_min INTEGER,  salary_max INTEGER,  improvement_plan TEXT,  created_at TIMESTAMP DEFAULT NOW());CREATE TABLE cheat_logs (  id SERIAL PRIMARY KEY,  assessment_id INTEGER REFERENCES assessments(id),  event_type VARCHAR(100),  penalty_applied INTEGER DEFAULT 0,  created_at TIMESTAMP DEFAULT NOW());CREATE TABLE questions (  id SERIAL PRIMARY KEY,  domain VARCHAR(100),  question_text TEXT NOT NULL,  option_a TEXT,  option_b TEXT,  option_c TEXT,  option_d TEXT,  correct_answer CHAR(1),  difficulty VARCHAR(50));CREATE TABLE test_answers (  id SERIAL PRIMARY KEY,  assessment_id INTEGER REFERENCES assessments(id),  question_id INTEGER REFERENCES questions(id),  selected_answer CHAR(1),  is_correct BOOLEAN,  time_taken INTEGER);CREATE TABLE email_logs (  id SERIAL PRIMARY KEY,  assessment_id INTEGER REFERENCES assessments(id),  recipient_email VARCHAR(255),  type VARCHAR(100),  sent_at TIMESTAMP DEFAULT NOW(),  status VARCHAR(50));
